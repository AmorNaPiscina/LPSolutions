# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname
NODE_ENV=production

# CORS — URL do frontend no Vercel
CORS_ORIGIN=https://lp-solutions.vercel.app

# Email (SMTP)
# Para Gmail: ative "Senhas de app" em myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app_gmail
SMTP_FROM="AgendaMercado <seuemail@gmail.com>"

# Email do recebedor/admin — quem recebe alertas de novos agendamentos
ADMIN_EMAIL=recebedor@email.com

# WhatsApp (Twilio)
# Crie conta em twilio.com, ative o sandbox WhatsApp em console.twilio.com/messaging/whatsapp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox: +14155238886 | Número aprovado em produção: +55119...
TWILIO_WHATSAPP_FROM=+14155238886
